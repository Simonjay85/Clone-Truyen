{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Local Server",
      "type": "shell",
      "command": "python3",
      "args": ["-m", "http.server", "8000"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}