<!-- CSS tối ưu cho lazy loading và genre filter -->
<style>
    
</style>

<script>
    // ====================================================
    // BẢNG XẾP HẠNG TỐI ỨU HÓA VỚI LAZY LOADING
    // Load truyện và user ranking qua AJAX 
    // Performance target: < 3 giây cho mọi period
    // ====================================================

    let currentStoryPeriod = 'day';
    let currentUserPeriod = 'day';
    let currentStoryGenre = '';
    let currentUserGenre = '';
    const mode = 'live';
    let isStoryRankingLoaded = false;
    let isUserRankingLoaded = false;
    let genres = [];

    // Load genres from server
    function loadGenres() {
        $.ajax({
            url: 'sources/ajax/mongdaovien/get-genres.php',
            type: 'GET',
            dataType: 'json',
            success: function(response) {
                if (response.status === 'success') {
                    genres = response.data;
                    let options = '<option value="">Tất cả thể loại</option>';
                    genres.forEach(genre => {
                        options += `<option value="${genre.alias}">${genre.ten}</option>`;
                    });
                    $('.genre-select').html(options);
                } else {
                    console.error('Error loading genres:', response.message);
                }
            },
            error: function(xhr, status, error) {
                console.error('Error loading genres:', error);
            }
        });
    }

    // Intersection Observer cho lazy loading
    const createIntersectionObserver = (callback) => {
        return new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    callback();
                }
            });
        }, {
            threshold: 0.1,
            rootMargin: '50px'
        });
    };

    // Load story ranking
    function getStoryRanking(period, genre = '') {
        console.log('Loading story ranking for period:', period, 'genre:', genre);
        currentStoryPeriod = period;
        currentStoryGenre = genre;

        const loadingHtml = `
            <div class="col-12 text-center p-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Đang tải bảng xếp hạng ${period}...</span>
                </div>
            </div>
        `;

        $('#result-story-ranking').html(loadingHtml);

        $.ajax({
            url: 'sources/ajax/mongdaovien/get-story-ranking.php',
            type: 'POST',
            dataType: 'json',
            data: {
                period: period,
                genre: genre,
                limit: 10
            },
            timeout: 5000,
            success: function(response) {
                console.log('Story Ranking Response:', response);

                if (response.status === 'success' && response.html) {
                    $('#result-story-ranking').fadeOut(100, function() {
                        $(this).html(response.html).addClass('ranking-fade-in').fadeIn(200);
                    });

                    if (response.execution_time) {
                        console.log(`Story ranking loaded in ${response.execution_time}`);
                    }
                } else {
                    $('#result-story-ranking').html(`
                        <div class="alert alert-warning text-center">
                            Không có dữ liệu bảng xếp hạng truyện cho ${period.toUpperCase()}
                        </div>
                    `);
                }
            },
            error: function(xhr, status, error) {
                console.error('Story Ranking Error:', error);
                $('#result-story-ranking').html(`
                    <div class="alert alert-danger text-center">
                        Lỗi tải bảng xếp hạng: ${error}
                    </div>
                `);
            }
        });
    }

    // Load user ranking
    function getUserRanking(mode, period, genre = '') {
        console.log('Loading user ranking with mode:', mode, 'period:', period, 'genre:', genre);
        currentUserPeriod = period;
        currentUserGenre = genre;

        $.ajax({
            url: 'sources/ajax/mongdaovien/get-user-ranking.php',
            type: 'POST',
            dataType: 'json',
            data: {
                mode: mode,
                period: period,
                genre: genre
            },
            timeout: 5000,
            success: function(response) {
                console.log('User Ranking Response:', response);

                if (response.status == 'success') {
                    if (response.data && response.data.length > 0) {
                        var html = '';
                        for (var i = 0; i < response.data.length; i++) {
                            html += response.data[i].html;
                        }

                        $('#result-user-ranking').fadeOut(100, function() {
                            $(this).html(html).addClass('ranking-fade-in').fadeIn(200);
                        });

                        if (response.execution_time) {
                            console.log(`User ranking loaded in ${response.execution_time}`);
                        }
                    } else {
                        $('#result-user-ranking').html('<div class="col-12 justify-content-center text-center alert alert-warning">Không có dữ liệu bảng xếp hạng cho ' + period + '</div>');
                    }
                } else {
                    $('#result-user-ranking').html('<div class="col-12 justify-content-center text-center alert alert-danger">Lỗi: ' + (response.message || 'Không thể tải dữ liệu') + '</div>');
                }
            },
            error: function(xhr, status, error) {
                console.log('User Ranking Error:', xhr, status, error);
                $('#result-user-ranking').html('<div class="col-12 justify-content-center text-center alert alert-danger">Lỗi kết nối: ' + error + '</div>');
            }
        });
    }

    // Setup lazy loading observers
    function initializeLazyLoading() {
        // Observer cho story ranking
        const storySection = document.querySelector('#result-story-ranking');
        if (storySection) {
            const storyObserver = createIntersectionObserver(() => {
                if (!isStoryRankingLoaded) {
                    getStoryRanking(currentStoryPeriod, currentStoryGenre);
                    isStoryRankingLoaded = true;
                    storyObserver.disconnect();
                }
            });
            storyObserver.observe(storySection);
        }

        // Observer cho user ranking  
        const userSection = document.querySelector('#result-user-ranking');
        if (userSection) {
            const userObserver = createIntersectionObserver(() => {
                if (!isUserRankingLoaded) {
                    getUserRanking(mode, currentUserPeriod, currentUserGenre);
                    isUserRankingLoaded = true;
                    userObserver.disconnect();
                }
            });
            userObserver.observe(userSection);
        }
    }

    // Document ready
    $(document).ready(function() {
        // Load genres
        loadGenres();

        // Initialize lazy loading
        initializeLazyLoading();

        // Story ranking tab handlers
        $('.story-ranking-tab-button').click(function() {
            const period = $(this).data('period');
            $('.story-ranking-tab-button').removeClass('active');
            $(this).addClass('active');

            // Show/hide genre filter
            if (period === 'all') {
                $('.story-genre-filter').addClass('show');
                loadGenres();
            } else {
                $('.story-genre-filter').removeClass('show');
                currentStoryGenre = '';
            }

            getStoryRanking(period, currentStoryGenre);
        });

        // User ranking tab handlers
        $('.user-ranking-tab-button').click(function() {
            const period = $(this).data('period');
            $('.user-ranking-tab-button').removeClass('active');
            $(this).addClass('active');

            // Show/hide genre filter
            if (period === 'all') {
                $('.user-genre-filter').addClass('show');
            } else {
                $('.user-genre-filter').removeClass('show');
                currentUserGenre = '';
            }

            getUserRanking(mode, period, currentUserGenre);
        });

        // Genre select handlers
        $('.story-genre-select').change(function() {
            currentStoryGenre = $(this).val();
            getStoryRanking(currentStoryPeriod, currentStoryGenre);
        });

        $('.user-genre-select').change(function() {
            currentUserGenre = $(this).val();
            getUserRanking(mode, currentUserPeriod, currentUserGenre);
        });

        // Show/hide genre filter based on active tab
        function updateGenreFilterVisibility() {
            if ($('#story-all-tab').hasClass('active')) {
                $('.story-genre-filter').addClass('show');
            } else {
                $('.story-genre-filter').removeClass('show');
            }

            if ($('#translator-all-tab').hasClass('active')) {
                $('.user-genre-filter').addClass('show');
            } else {
                $('.user-genre-filter').removeClass('show');
            }
        }

        // Update on tab click
        $('.story-ranking-tab-button, .user-ranking-tab-button').click(function() {
            updateGenreFilterVisibility();
        });

        // Initial visibility check
        updateGenreFilterVisibility();
    });
</script>
    <!-- Lazy: Truyện hoàn thành -->
