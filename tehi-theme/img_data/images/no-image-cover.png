    <script type="text/javascript" src="templates/js/jquery.twbsPagination.js"></script>

    <script>
        $(document).ready(function() {
            let currentPage = 1;
            let totalPages = 1; // Tổng số trang, sẽ được lấy từ server
            const limit = 18; // Số lượng truyện mỗi trang

            // Khởi tạo phân trang
            initializePagination();
            loadTruyenHoanThanh(currentPage);

            function initializePagination() {
                $('#pagination-truyen-hoan-thanh').twbsPagination('destroy');
                $('#pagination-truyen-hoan-thanh').twbsPagination({
                    totalPages: totalPages,
                    visiblePages: 4,
                    startPage: currentPage,
                    prev: '<span aria-hidden="true">&laquo;</span>',
                    next: '<span aria-hidden="true">&raquo;</span>',
                    onPageClick: function(event, page) {
                        if (page !== currentPage) {
                            currentPage = page;
                            loadTruyenHoanThanh(page);

                        }
                    }
                });
            }

            // Hàm load danh sách truyện
            function loadTruyenHoanThanh(page) {
                $.ajax({
                    url: 'sources/ajax/mongdaovien/load-truyen-hoan-thanh.php',
                    type: 'POST',
                    dataType: 'json',
                    data: {
                        page: page,
                        limit: limit,
                        screen_width: $(window).width(), // Gửi width để hỗ trợ device detection
                    },
                    success: function(response) {
                        if (response.status === 'success') {
                            // Debug: Log sorting method being used
                            if (typeof response.order_type !== 'undefined') {
                                console.log('Truyen Hoan Thanh - Device:', response.is_mobile ? 'Mobile/Tablet' : 'Desktop');
                                console.log('Truyen Hoan Thanh - Order Type:', response.order_type);
                            }

                            $('#result-truyen-hoan-thanh').fadeOut(200, function() {
                                $(this).html(response.html).fadeIn(200, function() {
                                    // Các tác vụ bổ sung như lazy load
                                    // initializeVHSkeleton();
                                });
                            });

                            if (response.total_page !== totalPages) {
                                totalPages = response.total_page;
                                initializePagination();
                            }
                        } else {
                            $('#result-truyen-hoan-thanh').html('<div class="text-center text-muted">Không có truyện nào!</div>');
                        }
                    },
                    error: function() {
                        $('#result-truyen-hoan-thanh').html('<div class="text-center text-danger">Lỗi khi tải danh sách truyện!</div>');
                    }
                });
            }
        });
    </script>


</main>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        swiper_truyen_moi_cap_nhat();

        // swiperJs - Truyện mới cập nhật
        function swiper_truyen_moi_cap_nhat() {
            var swiper_truyen_moi_cap_nhat = new Swiper(".truyen-comics-updated-swiper", {
                slidesPerView: 1,
                spaceBetween: 0,
                speed: 1000,
                autoplay: {
                    delay: 2500,
                    disableOnInteraction: false,
                },
                pagination: {
                    el: ".swiper-pagination-updated",
                    clickable: true,
                },
                breakpoints: {
                    768: {
                        slidesPerView: 2,
                    },
                },
            });
        }

        // SwiperJS - Truyện đề cử
        function swiper_truyen_de_cu() {
            if (document.querySelector('.truyen-comics-swiper')) {
                const comicsSwiper = new Swiper(".truyen-comics-swiper", {
                    slidesPerView: 2,
                    spaceBetween: 10,
                    pagination: {
                        el: ".truyen-moi-v1-de-cu-pagination",
                        clickable: true,
                    },
                    lazy: true,
                    speed: 800,
                    autoplay: {
                        delay: 2500,
                        disableOnInteraction: false,
                    },
                    breakpoints: {
                        320: {
                            slidesPerView: 2,
                            spaceBetween: 10,
                        },
                        480: {
                            slidesPerView: 3,
                            spaceBetween: 15,
                        },
                        768: {
                            slidesPerView: 4,
                            spaceBetween: 20,
                        },
                        992: {
                            slidesPerView: 6,
                            spaceBetween: 20,
                        },
                        1200: {
                            slidesPerView: 8,
                            spaceBetween: 20,
                        },
                    },
                    watchSlidesProgress: true,
                });
                console.log('✅ Truyện đề cử SwiperJS initialized:', comicsSwiper);
                return comicsSwiper;
            }
        }

        // khởi tạo tooltip
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function(tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });

        // Lazy loading cho các sections
        const lazySections = document.querySelectorAll('.lazy-section');

        function loadSection(section) {
            const url = section.getAttribute('data-url');
            if (!url) return;

            fetch(url)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    return response.json();
                })
                .then(data => {
                    if (data.status === 'success') {
                        section.innerHTML = data.html;
                        console.log(`✅ Loaded section: ${section.id}`);
                        
                        // Initialize SwiperJS based on section
                        if (section.id === 'lazy-truyen-moi-cap-nhat') {
                            swiper_truyen_moi_cap_nhat();
                        } else if (section.id === 'lazy-truyen-de-cu') {
                            // Initialize SwiperJS cho truyện đề cử
                            setTimeout(() => {
                                swiper_truyen_de_cu();
                            }, 100); // Small delay để đảm bảo DOM ready
                        }
                    } else {
                        throw new Error(data.message || 'Unknown error');
                    }
                })
                .catch(error => {
                    console.error(`❌ Error loading ${section.id}:`, error);
                    section.innerHTML = `
                        <div class="alert alert-danger text-center" role="alert">
                            <i class="fas fa-exclamation-triangle"></i>
                            Lỗi tải nội dung: ${error.message}
                            <button class="btn btn-sm btn-outline-danger ms-2" onclick="this.closest('.lazy-section').querySelector('[data-url]') && loadSection(this.closest('.lazy-section'))">
                                Thử lại
                            </button>
                        </div>
                    `;
                });
        }

        // Load tất cả sections sau khi DOM ready
        lazySections.forEach(section => {
            setTimeout(() => loadSection(section), 100); // Delay nhỏ để UI responsive
        });

        console.log('🚀 Lazy loading initialized for', lazySections.length, 'sections');
    });
</script>  </div>

