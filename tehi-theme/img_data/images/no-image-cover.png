    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize Horizontal Notification Slider
            const horizontalSlider = new Swiper('.hnb-slider', {
                slidesPerView: 1,
                spaceBetween: 10,
                loop: true,
                autoplay: {
                    delay: 5000,
                    disableOnInteraction: false,
                },
                effect: 'slide',
                speed: 800,
                navigation: {
                    nextEl: '.hnb-nav-next',
                    prevEl: '.hnb-nav-prev',
                },
                pagination: {
                    el: '.hnb-pagination',
                    clickable: true,
                    bulletClass: 'swiper-pagination-bullet',
                    bulletActiveClass: 'swiper-pagination-bullet-active',
                },
                on: {
                    slideChange: function() {
                        // Add entrance animation
                        const activeSlide = this.slides[this.activeIndex];
                        const item = activeSlide.querySelector('.hnb-item');
                        if (item) {
                            item.style.transform = 'translateX(20px)';
                            item.style.opacity = '0';
                            setTimeout(() => {
                                item.style.transform = 'translateX(0)';
                                item.style.opacity = '1';
                            }, 100);
                        }
                    }
                }
            });

            // Pause autoplay on hover
            const notificationBar = document.querySelector('.hnb-notification-bar');
            if (notificationBar && horizontalSlider) {
                notificationBar.addEventListener('mouseenter', () => {
                    horizontalSlider.autoplay.stop();
                });

                notificationBar.addEventListener('mouseleave', () => {
                    horizontalSlider.autoplay.start();
                });
            }
        });
    </script>


